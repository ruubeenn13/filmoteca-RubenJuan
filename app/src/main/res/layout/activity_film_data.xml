<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    tools:context=".FilmDataActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/layoutButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivFilmImage"
                    android:layout_width="120dp"
                    android:layout_height="180dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/film_poster"
                    android:background="@color/divider"
                    tools:src="@mipmap/ic_launcher" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvFilmTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        tools:text="Interstellar"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_text"
                        android:maxLines="3"
                        android:ellipsize="end" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/director"
                        android:textSize="14sp"
                        android:textColor="@color/secondary_text"
                        android:textStyle="italic" />

                    <TextView
                        android:id="@+id/tvFilmDirector"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Christopher Nolan"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/year"
                        android:textSize="14sp"
                        android:textColor="@color/secondary_text"
                        android:textStyle="italic" />

                    <TextView
                        android:id="@+id/tvFilmYear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="1984"
                        android:textSize="16sp"
                        android:textColor="@color/primary_text" />

                    <TextView
                        android:id="@+id/tvFilmFormatGenre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        tools:text="Digital, Scifi"
                        android:textSize="14sp"
                        android:textColor="@color/secondary_text" />

                    <Button
                        android:id="@+id/btnViewImdb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/view_imdb"
                        android:backgroundTint="@color/primary"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/tvFilmComments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                tools:text="A team of explorers travel through a wormhole in space in an attempt to ensure humanity's survival."
                android:textSize="14sp"
                android:textColor="@color/secondary_text"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnBackToMain"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/back_to_main"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnEditFilm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/edit_film"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>